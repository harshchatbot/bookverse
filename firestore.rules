rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'harshveernirwan@gmail.com'
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function validIndianMobile(value) {
      return value is string && value.matches('^\\+91[6-9][0-9]{9}$');
    }

    function validPincode(value) {
      return value is string && value.matches('^[0-9]{6}$');
    }

    function validIndianContactPhone(value) {
      return value is string
        && (value.matches('^[6-9][0-9]{9}$') || value.matches('^\\+91[6-9][0-9]{9}$'));
    }

    function nonEmpty(value) {
      return value is string && value.size() > 0;
    }

    function validPickupEmail(value) {
      return value is string && value.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$');
    }

    function validPickupAddress(value) {
      return value is map
        && value.keys().hasOnly([
          'pickupLocationName',
          'name',
          'phone',
          'email',
          'houseOrFlat',
          'buildingOrSociety',
          'streetOrRoad',
          'areaOrLocality',
          'address1',
          'address2',
          'city',
          'state',
          'pincode',
          'country',
          'landmark',
          'address',
          'location',
          'lat',
          'lon',
          'placeId',
          'formattedAddress',
          'sellerConfirmed',
          'pinConfirmedAt',
          'googleValidatedAt',
          'googleValidation',
          'isCourierReady',
          'validationLevel'
        ])
        && nonEmpty(value.pickupLocationName)
        && nonEmpty(value.name)
        && validIndianContactPhone(value.phone)
        && validPickupEmail(value.email)
        && (
          (
            ('houseOrFlat' in value && nonEmpty(value.houseOrFlat))
            && ('areaOrLocality' in value && nonEmpty(value.areaOrLocality))
            && ('landmark' in value && nonEmpty(value.landmark))
          )
          || nonEmpty(value.address1)
        )
        && nonEmpty(value.city)
        && nonEmpty(value.state)
        && validPincode(value.pincode)
        && nonEmpty(value.country)
        && (!('placeId' in value) || value.placeId is string)
        && (!('formattedAddress' in value) || value.formattedAddress is string)
        && (!('lat' in value) || value.lat is number)
        && (!('lon' in value) || value.lon is number)
        && (!('sellerConfirmed' in value) || value.sellerConfirmed is bool)
        && (!('pinConfirmedAt' in value) || value.pinConfirmedAt == null || value.pinConfirmedAt is string)
        && (!('googleValidatedAt' in value) || value.googleValidatedAt == null || value.googleValidatedAt is string)
        && (!('isCourierReady' in value) || value.isCourierReady is bool)
        && (!('validationLevel' in value)
            || value.validationLevel == null
            || value.validationLevel in ['google_validated', 'google_geo_confirmed', 'needs_more_detail', 'failed'])
        && (!('googleValidation' in value) || (
          value.googleValidation is map
          && value.googleValidation.keys().hasOnly([
            'addressComplete',
            'validationGranularity',
            'geocodeGranularity',
            'reasonCodes',
            'message'
          ])
          && (!('addressComplete' in value.googleValidation) || value.googleValidation.addressComplete is bool)
          && (!('validationGranularity' in value.googleValidation) || value.googleValidation.validationGranularity == null || value.googleValidation.validationGranularity is string)
          && (!('geocodeGranularity' in value.googleValidation) || value.googleValidation.geocodeGranularity == null || value.googleValidation.geocodeGranularity is string)
          && (!('reasonCodes' in value.googleValidation) || value.googleValidation.reasonCodes is list)
          && (!('message' in value.googleValidation) || value.googleValidation.message is string)
        ));
    }

    function phoneTokenMatches(data) {
      return request.auth.token.phone_number is string
        && (
          request.auth.token.phone_number == data.mobile
          || request.auth.token.phone_number == data.whatsappNumber
        );
    }

    function validMarketplaceProfileData(data) {
      return nonEmpty(data.name)
        && validIndianMobile(data.mobile)
        && validIndianMobile(data.whatsappNumber)
        && nonEmpty(data.state)
        && nonEmpty(data.city)
        && validPincode(data.pincode);
    }

    function hasVerifiedMarketplaceProfile(uid) {
      return isSignedIn()
        && request.auth.uid == uid
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/users/$(uid))
        && userDoc(uid).data.emailVerified == true
        && userDoc(uid).data.phoneVerified == true
        && validMarketplaceProfileData(userDoc(uid).data);
    }

    function validUserWrite(uid) {
      return isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.emailVerified == request.auth.token.email_verified
        && request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'emailVerified',
          'mobile',
          'whatsappNumber',
          'phoneVerified',
          'phoneVerifiedAt',
          'state',
          'city',
          'address',
          'pincode',
          'locality',
          'role',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.role in ['buyer', 'seller', 'admin']
        && (
          request.resource.data.role != 'admin'
          || request.auth.token.email == 'harshveernirwan@gmail.com'
          || isAdmin()
        )
        && (
          request.resource.data.phoneVerified == false
          || phoneTokenMatches(request.resource.data)
          || isAdmin()
        );
    }

    function validListingCreate() {
      return request.resource.data.keys().hasOnly([
          'title',
          'author',
          'category',
          'edition',
          'originalPrice',
          'sellingPrice',
          'condition',
          'state',
          'city',
          'deliveryType',
          'description',
          'images',
          'sellerUid',
          'sellerName',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'title',
          'author',
          'category',
          'originalPrice',
          'sellingPrice',
          'condition',
          'state',
          'city',
          'deliveryType',
          'description',
          'images',
          'sellerUid',
          'sellerName',
          'status'
        ])
        && request.resource.data.sellerUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && nonEmpty(request.resource.data.title)
        && nonEmpty(request.resource.data.author)
        && nonEmpty(request.resource.data.sellerName)
        && nonEmpty(request.resource.data.state)
        && nonEmpty(request.resource.data.city)
        && request.resource.data.images is list
        && request.resource.data.sellingPrice is number
        && request.resource.data.sellingPrice > 0;
    }

    match /listings/{listingId} {
      allow read: if resource.data.status in ['approved', 'sold']
                  || (isSignedIn() && resource.data.sellerUid == request.auth.uid)
                  || isAdmin();
      allow create: if isSignedIn()
                    && hasVerifiedMarketplaceProfile(request.auth.uid)
                    && validListingCreate();
      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.sellerUid == request.auth.uid
                        && resource.data.status == 'approved'
                        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                          'status',
                          'updatedAt'
                        ])
                        && request.resource.data.status == 'sold');
      allow delete: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if resource.data.status in ['approved', 'sold']
                  || (isSignedIn() && resource.data.sellerUid == request.auth.uid)
                  || isAdmin();
      allow create: if isSignedIn()
                    && hasVerifiedMarketplaceProfile(request.auth.uid)
                    && validListingCreate();
      allow update, delete: if isAdmin();
    }

    match /profiles/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isSignedIn()
                   && request.auth.uid == uid
                   && request.resource.data.keys().hasOnly([
                     'displayName',
                     'photoURL',
                     'bio',
                     'city',
                     'mobile',
                     'pickupAddress',
                     'updatedAt'
                   ])
                   && (
                     !('pickupAddress' in request.resource.data)
                     || validPickupAddress(request.resource.data.pickupAddress)
                   );
    }

    match /users/{uid} {
      allow get: if isSignedIn()
                 && (
                   request.auth.uid == uid
                   || isAdmin()
                   || hasVerifiedMarketplaceProfile(request.auth.uid)
                 );
      allow list: if isAdmin();
      allow create: if validUserWrite(uid);
      allow update: if validUserWrite(uid)
                    && (
                      !('role' in resource.data)
                      || request.resource.data.role == resource.data.role
                      || request.auth.token.email == 'harshveernirwan@gmail.com'
                      || isAdmin()
                    );
      allow delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    match /offers/{offerId} {
      allow read: if isSignedIn() && (
        resource.data.buyerUid == request.auth.uid
        || resource.data.sellerUid == request.auth.uid
        || isAdmin()
      );
      allow create: if isSignedIn()
                    && hasVerifiedMarketplaceProfile(request.auth.uid)
                    && request.resource.data.buyerUid == request.auth.uid
                    && request.resource.data.buyerUid != request.resource.data.sellerUid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0;
      allow update: if isSignedIn()
                    && resource.data.buyerUid == request.auth.uid
                    && request.resource.data.buyerUid == resource.data.buyerUid
                    && request.resource.data.sellerUid == resource.data.sellerUid
                    && resource.data.status == 'pending'
                    && request.resource.data.status in ['pending', 'cancelled'];
      allow update: if isSignedIn()
                    && resource.data.sellerUid == request.auth.uid
                    && request.resource.data.buyerUid == resource.data.buyerUid
                    && request.resource.data.sellerUid == resource.data.sellerUid
                    && resource.data.status == 'pending'
                    && request.resource.data.status in ['accepted', 'declined'];
      allow update, delete: if isAdmin();
    }

    match /book_inquiries/{inquiryId} {
      allow read: if isSignedIn() && (
        resource.data.buyerUid == request.auth.uid
        || resource.data.sellerUid == request.auth.uid
        || isAdmin()
      );
      allow create: if isSignedIn()
                    && hasVerifiedMarketplaceProfile(request.auth.uid)
                    && request.resource.data.keys().hasOnly([
                      'listingId',
                      'listingTitle',
                      'sellerUid',
                      'buyerUid',
                      'buyerName',
                      'channel',
                      'createdAt'
                    ])
                    && request.resource.data.buyerUid == request.auth.uid
                    && request.resource.data.sellerUid != request.auth.uid
                    && request.resource.data.channel == 'whatsapp'
                    && nonEmpty(request.resource.data.listingId)
                    && nonEmpty(request.resource.data.listingTitle)
                    && nonEmpty(request.resource.data.sellerUid)
                    && nonEmpty(request.resource.data.buyerName);
      allow update, delete: if isAdmin();
    }

    match /wishlists/{uid} {
      allow read, write: if isSignedIn()
                         && request.auth.uid == uid
                         && hasVerifiedMarketplaceProfile(uid);
    }

    match /notifications/{id} {
  // Single doc read
  allow read: if isSignedIn() && resource.data.userUid == request.auth.uid;

  // List/query — needed for getNotificationsForUser, getUnreadCount
  allow list: if isSignedIn();

  // Create — admin SDK (server) only, or offer-based client creates
  allow create: if isAdmin()
                || (isSignedIn()
                    && request.resource.data.read == false
                    && request.resource.data.offerId is string
                    && (
                      (
                        request.resource.data.type == 'offer_received'
                        && get(/databases/$(database)/documents/offers/$(request.resource.data.offerId)).data.buyerUid == request.auth.uid
                        && get(/databases/$(database)/documents/offers/$(request.resource.data.offerId)).data.sellerUid == request.resource.data.userUid
                      )
                      || (
                        request.resource.data.type in ['offer_accepted', 'offer_declined', 'listing_sold']
                        && get(/databases/$(database)/documents/offers/$(request.resource.data.offerId)).data.sellerUid == request.auth.uid
                        && get(/databases/$(database)/documents/offers/$(request.resource.data.offerId)).data.buyerUid == request.resource.data.userUid
                      )
                    )
                );

  // Mark as read — own notifications only
  allow update: if isSignedIn()
                && resource.data.userUid == request.auth.uid
                && request.resource.data.userUid == resource.data.userUid;

  allow delete: if isAdmin();
}

    match /orders/{id} {
      allow read, write: if false;
    }

    match /payments/{id} {
      allow read, write: if false;
    }

    match /shipments/{id} {
      allow read, write: if false;
    }

    match /seller_payouts/{id} {
      allow read, write: if false;
    }

    match /carts/{id} {
      allow read, write: if false;
    }

    match /disputes/{id} {
      allow read, write: if false;
    }
  }
}
