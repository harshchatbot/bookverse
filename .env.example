NEXT_PUBLIC_API_BASE_URL=https://bookverse-api-tefr.onrender.com
NEXT_PUBLIC_ENABLE_PROTECTED_DELIVERY=true
NEXT_PUBLIC_RAZORPAY_MODE=live
NEXT_PUBLIC_RAZORPAY_KEY_ID=
NEXT_PUBLIC_RAZORPAY_TEST_KEY_ID=
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=bookverse-a0024
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only values stay unprefixed
RAZORPAY_MODE=live
# Legacy Vite-compatible public keys can remain during migration,
# but Next.js client components should read NEXT_PUBLIC_* values.
VITE_RAZORPAY_KEY_ID=
VITE_RAZORPAY_TEST_KEY_ID=
ADMIN_UID=
ADMIN_EMAIL=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_TEST_KEY_ID=
RAZORPAY_TEST_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
SHIPROCKET_MODE=mock
SHIPROCKET_AUTO_CREATE_AFTER_PAYMENT=false
SHIPROCKET_ALLOW_LIVE_ORDER_CREATION=false
